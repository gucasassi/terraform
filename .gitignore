# Terraform files
*.tfstate
*.tfstate.backup
*.tfplan
terraform.tfstate
terraform.tfstate.backup

# Crash log files
crash.log

# Lock files
*.lock.*

# Exclude any .terraform directories
**/.terraform/*

# Ignore .tfvars files that are meant to be kept private
*.tfvars

# Ignore override files as they're usually used to override resources locally and don't need to be committed
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# test directory
test/